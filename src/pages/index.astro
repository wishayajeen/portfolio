---
import Layout from '../layouts/Layout.astro'
import logoUrl from '../assets/logo.svg'
import pockyIdleUrl from '../assets/pocky-idle.svg'
import pockyWritingUrl from '../assets/pocky-writing.svg'

const logoSrc = typeof logoUrl === 'string' ? logoUrl : logoUrl.src;
const pockyIdleSrc = typeof pockyIdleUrl === 'string' ? pockyIdleUrl : pockyIdleUrl.src;
const pockyWritingSrc = typeof pockyWritingUrl === 'string' ? pockyWritingUrl : pockyWritingUrl.src;
---

<Layout>
  <div id="root"></div>

  <script is:inline define:vars={{ logoSrc, pockyIdleSrc, pockyWritingSrc }} type="text/babel">
const ASSETS = {
  logo: logoSrc,
  pockyIdle: pockyIdleSrc,
  pockyProfile: pockyWritingSrc,
};




/* ─── TWEAKS ─────────────────────────────────────────────────────── */
const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
  "heroHeadline": "Hi, I'm Jeen.\nI design systems\nthat think.",
  "accentColor": "#F3FE52",
  "showScrollHint": true,
  "workStyle": "rows"
} /*EDITMODE-END*/;

/* ─── HEADER ─────────────────────────────────────────────────────── */
const Header = () => {
  const [scrolled, setScrolled] = React.useState(false);
  const [menuOpen, setMenuOpen] = React.useState(false);

  React.useEffect(() => {
    const fn = () => setScrolled(window.scrollY > 40);
    window.addEventListener('scroll', fn);
    return () => window.removeEventListener('scroll', fn);
  }, []);

  const scrollTo = (id) => {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setMenuOpen(false);
  };

  const navStyle = {
    position: 'fixed', top: 0, left: 0, right: 0, zIndex: 100,
    transition: 'all 250ms cubic-bezier(0.22,1,0.36,1)',
    padding: '0 48px',
    background: scrolled || menuOpen ? 'rgba(10,10,10,0.96)' : 'transparent',
    backdropFilter: scrolled || menuOpen ? 'blur(16px)' : 'none',
    borderBottom: scrolled || menuOpen ? '1px solid rgba(255,255,255,0.08)' : '1px solid transparent',
  };

  const linkStyle = {
    fontFamily: "'DM Sans', sans-serif", fontSize: 14, fontWeight: 500,
    color: '#FAFAFA', background: 'none', border: 'none', cursor: 'pointer',
    padding: '6px 12px', borderRadius: 99, transition: 'color 150ms',
    letterSpacing: '0.01em',
  };

  return (
    <nav style={navStyle}>
      <div style={{ maxWidth: 1200, margin: '0 auto', height: 64, display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        {/* Logo */}
        <button onClick={() => window.scrollTo({ top: 0, behavior: 'smooth' })}
          style={{ display: 'flex', alignItems: 'center', gap: 8, background: 'none', border: 'none', cursor: 'pointer' }}>
          <img src={ASSETS.logo} width="26" height="26" alt="Jeen" style={{ borderRadius: '50%', padding: 2, background: '#FFFFFF', width: 32, height: 32, objectFit: 'cover' }} />
          <span style={{ fontFamily: "'Space Grotesk', sans-serif", fontWeight: 700, fontSize: 18, color: '#FAFAFA' }}>Jeen</span>
        </button>

        {/* Desktop nav */}
        <div className="nav-links-desktop" style={{ display: 'flex', alignItems: 'center', gap: 4 }}>
          {[['Playground', 'playground'], ['About', 'about'], ['Work', 'work']].map(([label, id]) => (
            <button key={id} className="nav-link" style={linkStyle} onClick={() => scrollTo(id)}>{label}</button>
          ))}
          <button className="nav-cta" onClick={() => scrollTo('footer')} style={{
            fontFamily: "'DM Sans', sans-serif", fontSize: 13, fontWeight: 600,
            background: '#F3FE52', color: '#0A0A0A', padding: '9px 20px',
            borderRadius: 99, border: '1.5px solid #F3FE52', cursor: 'pointer',
            marginLeft: 8, transition: 'transform 150ms, box-shadow 150ms',
            boxShadow: '2px 2px 0 0 rgba(243,254,82,0.4)',
          }}
            onMouseEnter={e => { e.currentTarget.style.transform = 'translateY(-1px)'; }}
            onMouseLeave={e => { e.currentTarget.style.transform = ''; }}
          >Say hi →</button>
        </div>

        {/* Mobile hamburger */}
        <button className="mobile-menu-btn" onClick={() => setMenuOpen(m => !m)} aria-label="Menu">
          <span style={{ transform: menuOpen ? 'rotate(45deg) translate(4px, 4px)' : 'none' }} />
          <span style={{ opacity: menuOpen ? 0 : 1 }} />
          <span style={{ transform: menuOpen ? 'rotate(-45deg) translate(4px, -4px)' : 'none' }} />
        </button>
      </div>

      {/* Mobile dropdown */}
      {menuOpen && (
        <div style={{
          background: 'rgba(10,10,10,0.98)', borderTop: '1px solid rgba(255,255,255,0.08)',
          padding: '8px 24px 24px', display: 'flex', flexDirection: 'column',
        }}>
          {[['Playground', 'playground'], ['About', 'about'], ['Work', 'work'], ['Say hi →', 'footer']].map(([label, id]) => (
            <button key={id} onClick={() => scrollTo(id)} style={{
              fontFamily: "'DM Sans', sans-serif", fontSize: 18, fontWeight: 500,
              color: id === 'footer' ? '#F3FE52' : '#FAFAFA',
              background: 'none', border: 'none', borderBottom: '1px solid rgba(255,255,255,0.06)',
              cursor: 'pointer', padding: '14px 0', textAlign: 'left',
            }}>{label}</button>
          ))}
        </div>
      )}
    </nav>
  );

};

/* ─── HERO ───────────────────────────────────────────────────────── */
const Hero = () => {
  const scrollTo = (id) => {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  return (
    <section id="hero" style={{
      background: '#0A0A0A', minHeight: '100vh', position: 'relative',
      overflow: 'hidden', display: 'flex', flexDirection: 'column',
    }}>
      {/* Subtle grid */}
      <div style={{
        position: 'absolute', inset: 0, opacity: 0.035,
        backgroundImage: 'linear-gradient(#FAFAFA 1px, transparent 1px), linear-gradient(90deg, #FAFAFA 1px, transparent 1px)',
        backgroundSize: '56px 56px', pointerEvents: 'none',
      }} />

      {/* Two-column layout: text left, Pocky right */}
      <div className="hero-grid" style={{
        flex: 1, display: 'grid', gridTemplateColumns: '1fr min(400px, 36vw)',
        maxWidth: 1280, margin: '0 auto', width: '100%',
        padding: '80px 48px 100px', gap: 48, alignItems: 'center',
        position: 'relative', zIndex: 1,
      }}>
        {/* LEFT: text */}
        <div className="hero-text">
          {/* Badge */}
          <div className="fade-up fade-up-1" style={{
            display: 'inline-flex', alignItems: 'center', gap: 8,
            background: 'rgba(243,254,82,0.12)', border: '1px solid rgba(243,254,82,0.3)',
            borderRadius: 99, padding: '6px 16px', marginBottom: 36
          }}>
            <span style={{ width: 6, height: 6, borderRadius: '50%', background: '#3DFE87', display: 'block', flexShrink: 0 }} />
            <span style={{ fontFamily: "'JetBrains Mono', monospace", fontSize: 12, color: '#F3FE52', letterSpacing: '0.05em' }}>
              Portfolio + living design system
            </span>
          </div>

          {/* Headline */}
          <h1 className="fade-up fade-up-2" style={{
            fontFamily: "'Space Grotesk', sans-serif",
            fontWeight: 700,
            fontSize: 'clamp(52px, 7.5vw, 100px)',
            lineHeight: 1.04,
            letterSpacing: '-0.03em',
            color: '#FAFAFA',
            textWrap: 'pretty',
            marginBottom: 28
          }}>
            Hi, I'm Jeen.<br />
            I design systems that{' '}
            <span style={{ color: '#F3FE52', position: 'relative' }}>
              think.
              {/* underline squiggle */}
              <svg style={{ position: 'absolute', bottom: 2, left: '-2%', width: '104%' }} viewBox="0 0 220 18" preserveAspectRatio="none" height="14">
                {/* Paintbrush-style: thick tapered stroke with slight roughness */}
                <path d="M4 12 Q30 5 70 10 Q110 15 150 9 Q180 5 216 11" stroke="#F3FE52" strokeWidth="8" fill="none" strokeLinecap="round" strokeLinejoin="round" opacity="0.5" />
                <path d="M2 11 Q40 6 80 11 Q120 16 160 8 Q188 4 218 10" stroke="#F3FE52" strokeWidth="5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
              </svg>
            </span>
          </h1>

          {/* Sub */}
          <p className="fade-up fade-up-3" style={{
            fontFamily: "'DM Sans', sans-serif", fontSize: 18, lineHeight: 1.7,
            color: '#C8C8C0', maxWidth: 460, marginBottom: 44,
            textWrap: 'pretty'
          }}>
            Designer at the intersection of AI and design systems. My mascot — and AI agent — is a cat named Pocky. 🐱
          </p>

          {/* CTAs */}
          <div className="fade-up fade-up-4" style={{ display: 'flex', gap: 12, flexWrap: 'wrap', alignItems: 'center' }}>
            <button
              style={{
                fontFamily: "'DM Sans', sans-serif", fontWeight: 600, fontSize: 15,
                background: '#F3FE52', color: '#0A0A0A', padding: '14px 30px',
                borderRadius: 99, border: '1.5px solid #F3FE52',
                boxShadow: '3px 3px 0 0 rgba(243,254,82,0.35)', cursor: 'pointer',
                transition: 'transform 200ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 200ms'
              }}
              onMouseEnter={(e) => {e.currentTarget.style.transform = 'translateY(-2px)';e.currentTarget.style.boxShadow = '5px 5px 0 0 rgba(243,254,82,0.4)';}}
              onMouseLeave={(e) => {e.currentTarget.style.transform = '';e.currentTarget.style.boxShadow = '3px 3px 0 0 rgba(243,254,82,0.35)';}}
              onMouseDown={(e) => {e.currentTarget.style.transform = 'translateY(2px)';e.currentTarget.style.boxShadow = 'none';}}
              onMouseUp={(e) => {e.currentTarget.style.transform = 'translateY(-2px)';e.currentTarget.style.boxShadow = '5px 5px 0 0 rgba(243,254,82,0.4)';}}
              onClick={() => scrollTo('work')}>
              
              See my work
            </button>
            <button
              style={{
                fontFamily: "'DM Sans', sans-serif", fontWeight: 500, fontSize: 15,
                background: 'transparent', color: '#FAFAFA', padding: '14px 30px',
                borderRadius: 99, border: '1.5px solid rgba(250,250,250,0.2)',
                cursor: 'pointer', transition: 'border-color 150ms, background 150ms'
              }}
              onMouseEnter={(e) => {e.currentTarget.style.borderColor = 'rgba(250,250,250,0.5)';e.currentTarget.style.background = 'rgba(250,250,250,0.05)';}}
              onMouseLeave={(e) => {e.currentTarget.style.borderColor = 'rgba(250,250,250,0.2)';e.currentTarget.style.background = 'transparent';}}
              onClick={() => scrollTo('playground')}>
              
              Explore playground →
            </button>
          </div>

          {/* Quick links row */}
          <div style={{ display: 'flex', gap: 20, marginTop: 56, alignItems: 'center' }}>
            <span style={{ fontFamily: "'JetBrains Mono', monospace", fontSize: 11, color: '#C8C8C0', letterSpacing: '0.08em', textTransform: 'uppercase' }}>Find me on</span>
            {[
            { label: 'Twitter / X', href: '#' },
            { label: 'GitHub', href: '#' },
            { label: 'LinkedIn', href: '#' }].
            map(({ label, href }) =>
            <a key={label} href={href}
            style={{
              fontFamily: "'DM Sans', sans-serif", fontSize: 13, color: '#9A9A90',
              textDecoration: 'none', transition: 'color 150ms',
              borderBottom: '1px solid transparent'
            }}
            onMouseEnter={(e) => {e.currentTarget.style.color = '#F3FE52';e.currentTarget.style.borderBottomColor = '#F3FE52';}}
            onMouseLeave={(e) => {e.currentTarget.style.color = '#9A9A90';e.currentTarget.style.borderBottomColor = 'transparent';}}>
              
                {label}
              </a>
            )}
          </div>
        </div>

        {/* RIGHT: Pocky in yellow circle */}
        <div className="pocky-circle" style={{
          width: 'min(360px, 32vw)', height: 'min(360px, 32vw)',
          borderRadius: '50%', background: '#F3FE52',
          position: 'relative', alignSelf: 'center', flexShrink: 0,
          overflow: 'hidden',
          transform: 'translateZ(0)',
          clipPath: 'circle(50% at 50% 50%)',
        }}>
          <img src={ASSETS.pockyIdle} alt="Pocky"
            style={{
              position: 'absolute', top: '50%', left: '50%',
              transform: 'translate(-50%, -50%)',
              width: '65%', height: 'auto',
              pointerEvents: 'none', userSelect: 'none',
              animation: 'float-centered 5s ease-in-out infinite',
            }} />
        </div>
      </div>

      {/* Scroll indicator */}
      <div style={{
        position: 'absolute', bottom: 32, left: '50%', transform: 'translateX(-50%)',
        display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 8,
        color: '#9A9A90', cursor: 'pointer', zIndex: 1
      }} onClick={() => scrollTo('playground')}>
        <span style={{ fontFamily: "'JetBrains Mono', monospace", fontSize: 10, letterSpacing: '0.1em', color: '#9A9A90' }}>SCROLL</span>
        <div style={{
          width: 24, height: 38, borderRadius: 12, border: '1.5px solid #6A6A60',
          display: 'flex', alignItems: 'flex-start', justifyContent: 'center', padding: 5
        }}>
          <div style={{
            width: 4, height: 8, borderRadius: 2, background: '#F3FE52',
            animation: 'scroll-indicator 1.8s ease-in-out infinite'
          }} />
        </div>
      </div>
    </section>);

};

/* ─── PLAYGROUND ─────────────────────────────────────────────────── */
const PlaygroundCard = ({ tag, title, desc, emoji, accent }) => {
  const [h, setH] = React.useState(false);
  return (
    <div className="play-card"
    style={{
      background: accent ? '#F3FE52' : '#FAFAFA',
      border: '1.5px solid #0A0A0A', borderRadius: 12,
      padding: '28px', boxShadow: h ? '5px 5px 0 0 #0A0A0A' : '3px 3px 0 0 #0A0A0A',
      transition: 'transform 200ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 200ms',
      cursor: 'pointer', display: 'flex', flexDirection: 'column', gap: 14
    }}
    onMouseEnter={() => setH(true)} onMouseLeave={() => setH(false)}>
      
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <span style={{
          fontFamily: "'DM Sans', sans-serif", fontSize: 11, fontWeight: 600,
          background: accent ? '#0A0A0A' : '#F3FE52', color: accent ? '#F3FE52' : '#0A0A0A',
          padding: '3px 10px', borderRadius: 99, border: '1.5px solid #0A0A0A',
          letterSpacing: '0.02em'
        }}>{tag}</span>
      </div>
      <div>
        <h3 style={{
          fontFamily: "'Space Grotesk', sans-serif", fontWeight: 600, fontSize: 20,
          color: '#0A0A0A', marginBottom: 8, lineHeight: 1.2
        }}>{title}</h3>
        <p style={{
          fontFamily: "'DM Sans', sans-serif", fontSize: 14, color: accent ? '#3A3A35' : '#6A6A60',
          lineHeight: 1.6
        }}>{desc}</p>
      </div>
      <span style={{
        fontFamily: "'DM Sans', sans-serif", fontSize: 13, fontWeight: 600,
        color: '#0A0A0A', opacity: h ? 1 : 0.4, transition: 'opacity 150ms', alignSelf: 'flex-start'
      }}>Explore →</span>
    </div>);

};

const DiaryCard = ({ date, title, tag, readTime }) => {
  const [h, setH] = React.useState(false);
  return (
    <div className="diary-card"
    style={{
      background: '#FAFAFA', border: '1.5px solid #0A0A0A', borderRadius: 12,
      padding: '20px 24px',
      boxShadow: h ? '5px 5px 0 0 #0A0A0A' : '3px 3px 0 0 #0A0A0A',
      transition: 'transform 200ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 200ms',
      cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 16
    }}
    onMouseEnter={() => setH(true)} onMouseLeave={() => setH(false)}>
      
      <div style={{
        width: 48, height: 48, background: '#0A0A0A', borderRadius: 8,
        display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center',
        flexShrink: 0
      }}>
        <span style={{ fontFamily: "'JetBrains Mono', monospace", fontSize: 16, fontWeight: 700, color: '#F3FE52', lineHeight: 1 }}>{date.split(' ')[0]}</span>
        <span style={{ fontFamily: "'JetBrains Mono', monospace", fontSize: 9, color: '#6A6A60', letterSpacing: '0.05em' }}>{date.split(' ')[1]}</span>
      </div>
      <div style={{ flex: 1, minWidth: 0 }}>
        <p style={{
          fontFamily: "'Space Grotesk', sans-serif", fontWeight: 600, fontSize: 16,
          color: '#0A0A0A', lineHeight: 1.3, marginBottom: 4, whiteSpace: 'nowrap',
          overflow: 'hidden', textOverflow: 'ellipsis'
        }}>{title}</p>
        <div style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
          <span style={{
            fontFamily: "'DM Sans', sans-serif", fontSize: 11, fontWeight: 600,
            background: '#F3FE52', color: '#0A0A0A', padding: '2px 8px',
            borderRadius: 4, border: '1px solid #0A0A0A'
          }}>{tag}</span>
          <span style={{ fontFamily: "'JetBrains Mono', monospace", fontSize: 11, color: '#9A9A90' }}>{readTime} read</span>
        </div>
      </div>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style={{ flexShrink: 0, opacity: h ? 1 : 0.3, transition: 'opacity 150ms, transform 150ms', transform: h ? 'translateX(2px)' : '' }}>
        <path d="M3 8h10M9 4l4 4-4 4" stroke="#0A0A0A" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round" />
      </svg>
    </div>);

};

const PlaygroundSection = () => {
  const experiments = [
  { tag: 'Experiment', title: 'Ask Pocky', desc: 'My AI design agent — query the design system, my process, and work history via chat.', emoji: '🐱', accent: true },
  { tag: 'Experiment', title: 'Token explorer', desc: 'Browse every design token as structured data. Filter by type, value, or usage context.', emoji: '🔍', accent: false },
  { tag: 'Experiment', title: 'Design dashboard', desc: 'A live public view of the system — components, colors, decisions, all in one place.', emoji: '📊', accent: false },
  { tag: 'Experiment', title: 'Component sandbox', desc: 'Interactive playground to test and compose components from the design system in real time.', emoji: '⚡', accent: false }];


  const diary = [
  { date: '22 APR', title: 'Why I made my portfolio a design system', tag: 'Essay', readTime: '5 min' },
  { date: '14 APR', title: 'Designing with AI: what actually changed', tag: 'Reflection', readTime: '8 min' },
  { date: '03 APR', title: 'Naming my AI agent after my cat (and why it matters)', tag: 'Process', readTime: '3 min' },
  { date: '21 MAR', title: 'Building a living design system from scratch', tag: 'Tutorial', readTime: '12 min' },
  { date: '09 MAR', title: "Design tokens are databases. Let's treat them that way.", tag: 'Opinion', readTime: '6 min' }];


  return (
    <section id="playground" className="playground-section" style={{ background: '#F5F5F0', padding: '100px 48px' }}>
      <div style={{ maxWidth: 1200, margin: '0 auto' }}>

        {/* Section header */}
        <div style={{ marginBottom: 56 }}>
          <div style={{
            fontFamily: "'JetBrains Mono', monospace", fontSize: 11, color: '#9A9A90',
            letterSpacing: '0.1em', textTransform: 'uppercase', marginBottom: 10
          }}>playground</div>
          <div style={{ display: 'flex', alignItems: 'flex-end', justifyContent: 'space-between', flexWrap: 'wrap', gap: 16 }}>
            <h2 style={{
              fontFamily: "'Space Grotesk', sans-serif", fontWeight: 700, fontSize: 'clamp(32px, 4vw, 52px)',
              color: '#0A0A0A', letterSpacing: '-0.025em', lineHeight: 1.1
            }}>
              Things I'm<br />building and writing
            </h2>
            <p style={{
              fontFamily: "'DM Sans', sans-serif", fontSize: 16, color: '#6A6A60',
              maxWidth: 340, lineHeight: 1.6, textWrap: 'pretty'
            }}>
              Experiments, tools, and ideas I'm exploring in the open. No gatekeeping — just building.
            </p>
          </div>
        </div>

        {/* Experiment cards */}
        <div style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fill, minmax(260px, 1fr))',
          gap: 16, marginBottom: 64
        }}>
          {experiments.map((e, i) => <PlaygroundCard key={i} {...e} />)}
        </div>

        {/* Diary header */}
        <div style={{
          display: 'flex', alignItems: 'center', gap: 16, marginBottom: 20,
          paddingBottom: 16, borderBottom: '1.5px solid #E8E8E0'
        }}>
          <span style={{
            fontFamily: "'Space Grotesk', sans-serif", fontWeight: 600, fontSize: 22, color: '#0A0A0A'
          }}>Diary</span>
          <span style={{
            fontFamily: "'JetBrains Mono', monospace", fontSize: 11, color: '#9A9A90'
          }}>{diary.length} entries</span>
          <a href="#" style={{
            marginLeft: 'auto', fontFamily: "'DM Sans', sans-serif", fontSize: 13,
            fontWeight: 500, color: '#0A0A0A', textDecoration: 'none',
            borderBottom: '1.5px solid #F3FE52', paddingBottom: 1
          }}>Read all</a>
        </div>

        {/* Diary cards */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
          {diary.map((d, i) => <DiaryCard key={i} {...d} />)}
        </div>
      </div>
    </section>);

};

/* ─── ABOUT ──────────────────────────────────────────────────────── */
const AboutSection = () => {
  const skills = ['Design systems', 'AI × design', 'Agentic UX', 'Design tokens', 'Building in public', 'Talks & content'];

  return (
    <section id="about" className="about-section" style={{ background: '#F3FE52', padding: '100px 48px', position: 'relative', overflow: 'hidden' }}>


      <div style={{ maxWidth: 1200, margin: '0 auto' }}>
        <div style={{
          display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 80, alignItems: 'center'
        }}>
          {/* Left: text */}
          <div>
            <div style={{
              fontFamily: "'JetBrains Mono', monospace", fontSize: 11, color: '#6A6A60',
              letterSpacing: '0.1em', textTransform: 'uppercase', marginBottom: 16
            }}>about me</div>
            <h2 style={{
              fontFamily: "'Space Grotesk', sans-serif", fontWeight: 700,
              fontSize: 'clamp(36px, 4.5vw, 60px)',
              color: '#0A0A0A', lineHeight: 1.1, letterSpacing: '-0.025em', marginBottom: 24
            }}>
              I learn by<br />building in public.
            </h2>
            <p style={{
              fontFamily: "'DM Sans', sans-serif", fontSize: 17, color: '#3A3A35',
              lineHeight: 1.7, marginBottom: 16, textWrap: 'pretty'
            }}>
              I'm a designer obsessed with the intersection of AI and design systems. I think design decisions should be structured, queryable, and alive — not buried in Figma files no one opens.
            </p>
            <p style={{
              fontFamily: "'DM Sans', sans-serif", fontSize: 17, color: '#3A3A35',
              lineHeight: 1.7, marginBottom: 32, textWrap: 'pretty'
            }}>
              This portfolio is the system. Pocky — my cat-turned-AI-agent — is the interface. The work speaks for itself.
            </p>
            <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
              {skills.map((s) =>
              <span key={s} style={{
                fontFamily: "'DM Sans', sans-serif", fontSize: 12, fontWeight: 600,
                padding: '6px 14px', borderRadius: 99,
                background: '#0A0A0A', color: '#F3FE52',
                border: '1.5px solid #0A0A0A'
              }}>{s}</span>
              )}
            </div>
          </div>

          {/* Right: Pocky card */}
          <div>
            <div style={{
              background: '#FAFAFA', border: '1.5px solid #0A0A0A', borderRadius: 16,
