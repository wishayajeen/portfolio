---
import Layout from '../../layouts/Layout.astro';
import '/src/styles/design-system.css';
import systemData from '../../system/system.json';

const title = "Dashboard — Design System — Jeen";
const description = "Discrepancies, decisions, and audit history for the Jeen design system.";

const resolvedCount  = systemData.discrepancies.filter((d: any) => d.status === 'resolved').length;
const openCount      = systemData.discrepancies.filter((d: any) => d.status === 'open').length;
const decisionCount  = systemData.discrepancies.filter((d: any) => d.status === 'decision').length;

const statusBadgeClass: Record<string, string> = {
  resolved: 'ds-badge ds-badge-success',
  open:     'ds-badge ds-badge-yellow',
  decision: 'ds-badge ds-badge-outline',
};
const statusLabel: Record<string, string> = {
  resolved: 'Resolved',
  open:     'Open',
  decision: 'Decision',
};
---

<Layout title={title} description={description}>

<!-- Sticky topbar -->
<div class="ds-topbar" id="ds-topbar">
  <a href="/" class="back-link">← Jeen.work</a>
  <span class="ds-topbar-sep">/</span>
  <a href="/design-system" class="ds-topbar-title">Design System</a>
  <div class="ds-topbar-tabs">
    <a href="/design-system/foundations" class="footer-nav-link">Foundations</a>
    <a href="/design-system/components" class="footer-nav-link">Components</a>
    <a href="/design-system/dashboard" class="footer-nav-link" aria-current="page">Dashboard</a>
  </div>
  <button class="mobile-menu-btn" aria-label="Toggle navigation" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</div>
<script>
  const bar = document.getElementById('ds-topbar');
  const btn = bar.querySelector('.mobile-menu-btn');
  btn.addEventListener('click', () => {
    const open = bar.classList.toggle('menu-open');
    btn.setAttribute('aria-expanded', String(open));
  });
  document.addEventListener('click', (e) => {
    if (!bar.contains(e.target)) bar.classList.remove('menu-open');
  });
</script>

<!-- Hero -->
<div class="ds-hero">
  <div class="ds-hero-inner">
    <p class="ds-hero-eyebrow">jeen design system — v{systemData.version}</p>
    <h1 class="ds-hero-title">Dashboard</h1>
  </div>
</div>

<div class="ds-page">

  <!-- ── STATS ── -->
  <section class="ds-section" id="stats">
    <div class="ds-section-header">
      <h2 class="ds-section-title">System stats</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:var(--space-4);margin-bottom:var(--space-8);">
      <div class="ds-card" style="text-align:center;">
        <p style="font-family:var(--font-display);font-size:var(--text-4xl);font-weight:700;color:var(--fg-primary);margin:0 0 var(--space-1);">{systemData.routes.length}</p>
        <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--fg-secondary);margin:0;text-transform:uppercase;letter-spacing:var(--tracking-wider);">Routes</p>
      </div>
      <div class="ds-card" style="text-align:center;">
        <p style="font-family:var(--font-display);font-size:var(--text-4xl);font-weight:700;color:var(--fg-primary);margin:0 0 var(--space-1);">{systemData.components.length}</p>
        <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--fg-secondary);margin:0;text-transform:uppercase;letter-spacing:var(--tracking-wider);">Components</p>
      </div>
      <div class="ds-card" style="text-align:center;">
        <p style="font-family:var(--font-display);font-size:var(--text-4xl);font-weight:700;color:var(--fg-primary);margin:0 0 var(--space-1);">{systemData.sections.length}</p>
        <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--fg-secondary);margin:0;text-transform:uppercase;letter-spacing:var(--tracking-wider);">Sections</p>
      </div>
      <div class="ds-card" style="text-align:center;">
        <p style="font-family:var(--font-display);font-size:var(--text-4xl);font-weight:700;color:var(--fg-primary);margin:0 0 var(--space-1);">{systemData.discrepancies.length}</p>
        <p style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--fg-secondary);margin:0;text-transform:uppercase;letter-spacing:var(--tracking-wider);">Discrepancies</p>
      </div>
    </div>
  </section>

  <!-- ── DISCREPANCIES ── -->
  <section class="ds-section" id="discrepancies">
    <div class="ds-section-header">
      <span class="ds-section-num">15</span>
      <h2 class="ds-section-title">Discrepancies & decisions</h2>
    </div>
    <p style="font-size:var(--text-sm);color:var(--fg-secondary);margin-bottom:var(--space-2);">
      Sourced from <code class="ds-code">system.json → discrepancies</code>. Updated automatically by <code class="ds-code">/review-ds</code> when issues are found or fixed.
    </p>
    <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-6);font-size:var(--text-xs);font-family:var(--font-mono);">
      <span><span class="ds-badge ds-badge-success" style="font-size:10px;">Resolved</span> {resolvedCount} — fixed and shipped</span>
      <span><span class="ds-badge ds-badge-yellow" style="font-size:10px;">Open</span> {openCount} — known, needs action</span>
      <span><span class="ds-badge ds-badge-outline" style="font-size:10px;">Decision</span> {decisionCount} — intentional deviation</span>
    </div>

    {systemData.discrepancies.map((disc) => (
      <div class="disc-card">
        <div class="disc-card-header">
          <span class={statusBadgeClass[disc.status]}>{statusLabel[disc.status]}</span>
          <h3 class="disc-card-title">{disc.title}</h3>
        </div>
        <p class="disc-card-body">{disc.body}</p>
        {disc.resolvedIn && (
          <p style="margin:var(--space-2) 0 0;font-size:10px;font-family:var(--font-mono);color:var(--fg-secondary);">
            resolved in commit {disc.resolvedIn} · {disc.date}
          </p>
        )}
        {!disc.resolvedIn && (
          <p style="margin:var(--space-2) 0 0;font-size:10px;font-family:var(--font-mono);color:var(--fg-secondary);">
            logged {disc.date}
          </p>
        )}
      </div>
    ))}
  </section>

</div><!-- end .ds-page -->

<!-- Footer -->
<div class="ds-footer">
  <div class="ds-footer-inner" style="justify-content: center;">
    <a href="#" onclick="window.scrollTo({ top: 0, behavior: 'smooth' }); return false;" class="ds-footer-link">↑ Top</a>
  </div>
</div>

</Layout>
