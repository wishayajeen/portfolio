      <h2 class="ds-section-title">Shadows & border radii</h2>
    </div>

    <div class="ds-subsection">
      <div class="ds-sub-label">Hard offset shadows — doodle aesthetic</div>
      <div class="ds-card">
        <div class="ds-row" style="align-items:flex-end;">
          {[
            ['shadow-xs', '1px 1px 0 0 #0A0A0A', 'translateY(-1px)'],
            ['shadow-sm', '2px 2px 0 0 #0A0A0A', 'translateY(-2px)'],
            ['shadow-md', '3px 3px 0 0 #0A0A0A', 'translateY(-3px)'],
            ['shadow-lg', '5px 5px 0 0 #0A0A0A', 'translateY(-5px)'],
            ['shadow-xl', '8px 8px 0 0 #0A0A0A', 'translateY(-8px)'],
