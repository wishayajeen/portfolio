      {[
        ['--space-1', 4, '4px'],
        ['--space-2', 8, '8px'],
        ['--space-3', 12, '12px'],
        ['--space-4', 16, '16px'],
        ['--space-5', 20, '20px'],
        ['--space-6', 24, '24px'],
        ['--space-8', 32, '32px'],
        ['--space-10', 40, '40px'],
        ['--space-12', 48, '48px'],
        ['--space-16', 64, '64px'],
        ['--space-20', 80, '80px — section-padding-y'],
        ['--space-24', 96, '96px'],
        ['--space-32', 128, '128px'],
      ].map(([token, px, label]) => (
        <div class="space-row">
          <div class="space-bar" style={`width:${Math.min(px, 256)}px;`}></div>
          <span class="space-label"><span class="ds-code">{token}</span>&nbsp; {label}</span>
