---
import '/src/styles/tokens.css';
const title = "Design System — Jeen";
const description = "A living design system. Tokens, principles, and components that power Jeen's portfolio.";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    /* ── Page shell ── */
    * { box-sizing: border-box; }
    body { margin: 0; background: var(--color-gray-100); font-family: var(--font-body); color: var(--fg-primary); }

    /* ── Layout ── */
    .ds-page { max-width: 1100px; margin: 0 auto; padding: 0 var(--space-6) var(--space-32); }

    /* ── Page header ── */
    .ds-topbar {
      background: var(--color-black);
      padding: var(--space-4) var(--space-6);
      display: flex; align-items: center; gap: var(--space-4);
      position: sticky; top: 0; z-index: 100;
    }
    .ds-topbar a {
      color: var(--color-gray-400); font-size: var(--text-sm);
      text-decoration: none; transition: color var(--duration-fast) var(--ease-out);
    }
    .ds-topbar a:hover { color: var(--color-yellow); }
    .ds-topbar-sep { color: var(--color-gray-700); font-size: var(--text-sm); }
    .ds-topbar-title { color: var(--color-white); font-size: var(--text-sm); font-weight: 600; }

    .ds-hero {
      background: var(--color-black);
      padding: var(--space-16) var(--space-6) var(--space-12);
      margin-bottom: var(--space-12);
    }
    .ds-hero-inner { max-width: 1100px; margin: 0 auto; }
    .ds-hero-eyebrow {
      font-family: var(--font-mono); font-size: var(--text-xs);
      color: var(--color-yellow); letter-spacing: var(--tracking-wider);
      text-transform: uppercase; margin-bottom: var(--space-4);
    }
    .ds-hero-title {
      font-family: var(--font-display); font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 700; letter-spacing: var(--tracking-tight); line-height: 1.1;
      color: var(--color-white); margin: 0 0 var(--space-4);
    }
    .ds-hero-title span { color: var(--color-yellow); }
    .ds-hero-sub {
      font-size: var(--text-lg); color: var(--color-gray-300);
      line-height: var(--leading-relaxed); max-width: 600px; margin: 0 0 var(--space-6);
    }
    .ds-hero-meta {
      display: flex; gap: var(--space-6); flex-wrap: wrap;
    }
    .ds-hero-meta-item { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-gray-400); }
    .ds-hero-meta-item strong { color: var(--color-gray-200); }

    /* ── Section ── */
    .ds-section { margin-bottom: var(--space-16); }
    .ds-section-header {
      display: flex; align-items: baseline; gap: var(--space-3);
      margin-bottom: var(--space-8);
      padding-bottom: var(--space-3);
      border-bottom: 1.5px solid var(--color-black);
    }
    .ds-section-num {
      font-family: var(--font-mono); font-size: var(--text-xs);
      color: var(--fg-tertiary); letter-spacing: var(--tracking-wide); min-width: 2.5ch;
    }
    .ds-section-title {
      font-family: var(--font-display); font-size: var(--text-2xl);
      font-weight: 700; color: var(--fg-primary); margin: 0;
    }

    .ds-subsection { margin-bottom: var(--space-8); }
    .ds-sub-label {
      font-size: var(--text-xs); font-weight: 600; text-transform: uppercase;
      letter-spacing: var(--tracking-wider); color: var(--fg-tertiary);
      margin-bottom: var(--space-4);
    }

    .ds-row { display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: flex-start; }
    .ds-col { display: flex; flex-direction: column; gap: var(--space-3); }

    /* ── Cards (container) ── */
    .ds-card {
      background: var(--bg-surface-raised);
      border: var(--border-primary);
      border-radius: var(--radius-md);
      padding: var(--space-6);
      box-shadow: var(--shadow-sm);
    }

    /* ── Color swatches ── */
    .swatch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: var(--space-3); }
    .swatch-item { border-radius: var(--radius-sm); overflow: hidden; border: var(--border-subtle); }
    .swatch-color { height: 56px; width: 100%; }
    .swatch-info { padding: var(--space-2) var(--space-3); background: var(--bg-surface-raised); }
    .swatch-name { font-family: var(--font-mono); font-size: 10px; font-weight: 600; color: var(--fg-primary); display: block; margin-bottom: 2px; }
    .swatch-hex  { font-family: var(--font-mono); font-size: 10px; color: var(--fg-tertiary); display: block; margin-bottom: 2px; }
    .swatch-use  { font-size: 10px; color: var(--fg-tertiary); line-height: 1.3; display: block; }

    /* ── Semantic color chips ── */
    .semantic-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-2); }
    .semantic-chip {
      display: flex; align-items: center; gap: var(--space-3);
      padding: var(--space-2) var(--space-3);
      background: var(--bg-surface-raised);
      border: var(--border-subtle);
      border-radius: var(--radius-sm);
    }
    .semantic-dot { width: 20px; height: 20px; border-radius: var(--radius-xs); border: 1px solid rgba(10,10,10,0.12); flex-shrink: 0; }
    .semantic-info { min-width: 0; }
    .semantic-token { font-family: var(--font-mono); font-size: 10px; font-weight: 600; color: var(--fg-primary); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .semantic-desc  { font-size: 10px; color: var(--fg-tertiary); line-height: 1.3; display: block; }

    /* ── Dark background text token demo ── */
    .dark-text-demo {
      background: var(--color-black);
      border: var(--border-primary);
      border-radius: var(--radius-md);
      padding: var(--space-6);
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: var(--space-4);
    }
    .dark-text-item { display: flex; flex-direction: column; gap: var(--space-1); }
    .dark-text-sample { font-size: var(--text-lg); font-weight: 600; line-height: 1; }
    .dark-text-token  { font-family: var(--font-mono); font-size: 10px; color: var(--color-gray-500); margin-top: var(--space-1); }
    .dark-text-ratio  { font-family: var(--font-mono); font-size: 10px; }

    /* ── Type scale ── */
    .type-specimen {
      display: flex; align-items: baseline; gap: var(--space-6);
      padding: var(--space-4) 0;
      border-bottom: 1px solid var(--color-gray-200);
    }
    .type-specimen:last-child { border-bottom: none; }
    .type-meta {
      font-family: var(--font-mono); font-size: 10px; color: var(--fg-tertiary);
      line-height: 1.5; min-width: 140px; flex-shrink: 0;
    }
    .type-sample { line-height: var(--leading-tight); overflow: hidden; }

    /* ── Spacing bars ── */
    .space-row { display: flex; align-items: center; gap: var(--space-4); margin-bottom: var(--space-2); }
    .space-bar { background: var(--color-yellow); border: 1.5px solid var(--color-black); height: 20px; flex-shrink: 0; }
    .space-label { font-family: var(--font-mono); font-size: 10px; color: var(--fg-tertiary); white-space: nowrap; }

    /* ── Shadow demos ── */
    .shadow-box {
      width: 64px; height: 64px;
      background: var(--color-yellow);
      border: 1.5px solid var(--color-black);
      border-radius: var(--radius-md);
    }
    .shadow-item { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); }
    .shadow-meta { font-family: var(--font-mono); font-size: 10px; color: var(--fg-tertiary); text-align: center; }

    /* Radius demos */
    .radius-box {
      width: 64px; height: 64px;
      background: var(--color-white);
      border: 1.5px solid var(--color-black);
      box-shadow: var(--shadow-md);
    }

    /* ── Background demos ── */
    .bg-swatch { height: 96px; border: 1.5px solid var(--color-black); border-radius: var(--radius-md); display: flex; align-items: flex-end; padding: var(--space-3); }
    .bg-label { font-family: var(--font-mono); font-size: 10px; font-weight: 600; border-radius: var(--radius-xs); padding: 2px 6px; }

    /* ── Buttons ── */
    .ds-btn {
      display: inline-flex; align-items: center; gap: var(--space-2);
      font-family: var(--font-body); font-weight: 600; font-size: 15px;
      padding: 12px 24px; border-radius: var(--radius-full);
      border: 1.5px solid var(--color-black); cursor: pointer;
      transition: transform var(--duration-fast) var(--ease-spring),
                  box-shadow var(--duration-fast) var(--ease-spring);
      text-decoration: none; white-space: nowrap;
    }
    .ds-btn:hover  { transform: translateY(-2px); }
    .ds-btn:active { transform: translateY(1px); }
    .ds-btn-primary { background: var(--color-yellow); color: var(--color-black); box-shadow: var(--shadow-md); }
    .ds-btn-primary:hover { box-shadow: var(--shadow-lg); }
    .ds-btn-primary:active { box-shadow: none; }
    .ds-btn-dark    { background: var(--color-black); color: var(--color-white); box-shadow: var(--shadow-md); }
    .ds-btn-dark:hover { box-shadow: var(--shadow-lg); }
    .ds-btn-outline { background: transparent; color: var(--color-black); box-shadow: var(--shadow-sm); }
    .ds-btn-outline:hover { background: var(--color-gray-100); box-shadow: var(--shadow-md); }
    .ds-btn-ghost   { background: transparent; color: var(--color-black); border-color: transparent; box-shadow: none; }
    .ds-btn-ghost:hover { background: var(--color-gray-100); }
    .ds-btn-sm { font-size: 13px; padding: 8px 16px; }
    .ds-btn:disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

    /* Simulated states */
    .state-hover  { transform: translateY(-2px); box-shadow: var(--shadow-lg) !important; }
    .state-active { transform: translateY(1px); box-shadow: none !important; }

    /* ── Badges ── */
    .ds-badge {
      display: inline-flex; align-items: center; gap: 5px;
      font-family: var(--font-body); font-size: 12px; font-weight: 500;
      padding: 4px 10px; border-radius: var(--radius-full);
      border: 1.5px solid var(--color-black);
    }
    .ds-badge-yellow  { background: var(--color-yellow); color: var(--color-black); }
    .ds-badge-dark    { background: var(--color-black);  color: var(--color-white); }
    .ds-badge-outline { background: transparent; color: var(--color-black); }
    .ds-badge-gray    { background: var(--color-gray-100); color: var(--color-gray-700); border-color: var(--color-gray-300); }
    .ds-badge-success { background: #3DFE87; color: var(--color-black); }
    .ds-badge-error   { background: #FF4444; color: var(--color-white); }
    /* Ghost — current project style */
    .ds-badge-ghost   { background: transparent; color: var(--color-gray-700); border: 1.5px solid var(--color-gray-300); }
    .ds-badge-coming  { background: transparent; color: #FF5050; border: 1.5px solid #FF5050; }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    /* Tags */
    .ds-tag {
      display: inline-flex; align-items: center;
      font-size: 11px; font-weight: 600; padding: 3px 8px;
      border-radius: var(--radius-xs); border: 1px solid currentColor;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .ds-tag-yellow { color: var(--color-black); background: var(--color-yellow-pale); border-color: var(--color-yellow-dim); }
    .ds-tag-mono   { font-family: var(--font-mono); background: var(--color-gray-100); color: var(--color-gray-700); border-color: var(--color-gray-200); }

    /* ── Cards ── */
    .ds-project-card {
      background: var(--color-white);
      border: 1.5px solid var(--color-black);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      box-shadow: var(--shadow-md);
      transition: transform var(--duration-base) var(--ease-spring),
                  box-shadow var(--duration-base) var(--ease-spring);
      width: 200px;
    }
    .ds-project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
    .card-tag-inner {
      display: inline-block; font-size: 11px; font-weight: 600;
      background: var(--color-yellow); color: var(--color-black);
      padding: 3px 10px; border-radius: var(--radius-full);
      border: 1.5px solid var(--color-black); margin-bottom: var(--space-2);
    }
    .card-title-inner { font-family: var(--font-display); font-size: 16px; font-weight: 600; color: var(--fg-primary); margin: 0 0 6px; }
    .card-body-inner  { font-size: 13px; color: var(--fg-secondary); line-height: 1.5; margin: 0; }
    .ds-project-card-dark { background: var(--color-black); }
    .ds-project-card-dark .card-tag-inner { background: var(--color-yellow); }
    .ds-project-card-dark .card-title-inner { color: var(--color-white); }
    .ds-project-card-dark .card-body-inner  { color: var(--color-gray-400); }
    .ds-project-card-dark:hover { box-shadow: 5px 5px 0 0 var(--color-yellow); }
    .ds-project-card-accent { background: var(--color-yellow); }
    .ds-project-card-accent .card-tag-inner { background: var(--color-black); color: var(--color-yellow); }

    /* ── Inputs ── */
    .ds-input-wrap { max-width: 400px; }
    .ds-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: var(--space-4); }
    .ds-field-label { font-size: 13px; font-weight: 500; color: var(--fg-primary); }
    .ds-input {
      font-family: var(--font-body); font-size: 15px;
      padding: 11px 14px; width: 100%;
      border: 1.5px solid var(--color-black); border-radius: var(--radius-md);
      background: var(--color-white); color: var(--fg-primary);
      box-shadow: var(--shadow-xs);
      outline: none;
    }
    .ds-input::placeholder { color: var(--fg-tertiary); }
    .ds-input.focused { box-shadow: 0 0 0 3px var(--color-yellow); }
    .ds-input.error   { border-color: #FF4444; box-shadow: 0 0 0 3px rgba(255,68,68,0.2); }
    .ds-input.disabled{ opacity: 0.5; cursor: not-allowed; background: var(--color-gray-100); }
    .ds-helper         { font-size: 12px; color: var(--fg-tertiary); }
    .ds-helper.err     { color: #FF4444; }
    .ds-ask-bar {
      display: flex; gap: var(--space-2); align-items: center;
      padding: 10px 10px 10px 16px;
      border: 1.5px solid var(--color-black); border-radius: var(--radius-full);
      background: var(--color-white); box-shadow: var(--shadow-md);
    }
    .ds-ask-input { border: none; outline: none; font-family: var(--font-body); font-size: 14px; flex: 1; background: transparent; }
    .ds-ask-btn {
      background: var(--color-yellow); border: 1.5px solid var(--color-black);
      border-radius: var(--radius-full); padding: 8px 16px;
      font-family: var(--font-body); font-size: 13px; font-weight: 600; cursor: pointer;
    }

    /* ── Principles grid ── */
    .principles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-4); }
    .principle-card {
      background: var(--bg-surface-raised);
      border: var(--border-primary);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      box-shadow: var(--shadow-sm);
    }
    .principle-icon { font-size: 1.5rem; margin-bottom: var(--space-2); }
    .principle-title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; margin: 0 0 var(--space-2); }
    .principle-body { font-size: var(--text-sm); color: var(--fg-secondary); line-height: var(--leading-relaxed); margin: 0; }

    /* ── Discrepancy flag ── */
    .flag-card {
      background: #FFF9E6;
      border: 2px solid var(--color-yellow);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      margin-bottom: var(--space-4);
    }
    .flag-header { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-2); }
    .flag-icon { font-size: 1rem; }
    .flag-title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: #5A4200; }
    .flag-body  { font-size: var(--text-sm); color: #5A4200; line-height: var(--leading-relaxed); margin: 0; }
    .flag-resolved {
      background: var(--color-gray-100);
      border-color: var(--color-gray-300);
    }
    .flag-resolved .flag-title,
    .flag-resolved .flag-body { color: var(--fg-secondary); }

    /* ── Table ── */
    .ds-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
    .ds-table th { text-align: left; font-weight: 600; padding: var(--space-2) var(--space-3); background: var(--color-gray-100); border-bottom: 1.5px solid var(--color-black); font-family: var(--font-display); font-size: var(--text-sm); }
    .ds-table td { padding: var(--space-2) var(--space-3); border-bottom: 1px solid var(--color-gray-200); vertical-align: middle; }
    .ds-table tr:last-child td { border-bottom: none; }
    .mono { font-family: var(--font-mono); font-size: var(--text-xs); }

    /* ── Animation token rows ── */
    .anim-row { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-3) 0; border-bottom: 1px solid var(--color-gray-200); }
    .anim-row:last-child { border-bottom: none; }
    .anim-demo { width: 48px; height: 48px; background: var(--color-yellow); border: 1.5px solid var(--color-black); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .anim-info { flex: 1; }
    .anim-name  { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; color: var(--fg-primary); }
    .anim-value { font-family: var(--font-mono); font-size: 10px; color: var(--fg-tertiary); margin-top: 2px; }

    /* ── Nav toc ── */
    .toc {
      position: fixed; right: var(--space-6); top: 50%;
      transform: translateY(-50%);
      display: flex; flex-direction: column; gap: var(--space-2);
      z-index: 90;
    }
    .toc-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--color-gray-300); border: none;
      cursor: pointer; padding: 0; transition: background var(--duration-fast);
      text-indent: -9999px;
    }
    .toc-dot.active, .toc-dot:hover { background: var(--color-black); }
    @media (max-width: 1280px) { .toc { display: none; } }

    /* ── Divider ── */
    .ds-divider { height: 1px; background: var(--color-gray-200); margin: var(--space-6) 0; }

    /* ── Code inline ── */
    .ds-code { font-family: var(--font-mono); font-size: var(--text-xs); background: var(--color-gray-100); padding: 2px 6px; border-radius: var(--radius-xs); color: var(--fg-primary); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .ds-hero { padding: var(--space-10) var(--space-4) var(--space-8); }
      .ds-page { padding: 0 var(--space-4) var(--space-20); }
      .type-meta { min-width: 100px; }
      .type-specimen { gap: var(--space-3); }
    }
  </style>
</head>
<body>

<!-- Sticky topbar -->
<div class="ds-topbar">
  <a href="/">← Jeen.work</a>
  <span class="ds-topbar-sep">/</span>
  <span class="ds-topbar-title">Design System</span>
  <span class="ds-topbar-sep" style="margin-left:auto;">v1.0 · April 2026</span>
</div>

<!-- Hero -->
<div class="ds-hero">
  <div class="ds-hero-inner">
    <p class="ds-hero-eyebrow">jeen design system — v1.0</p>
    <h1 class="ds-hero-title">A living <span>design system</span></h1>
    <p class="ds-hero-sub">
      Not a traditional portfolio. A structured, AI-queryable system that exists as data — visible through a dashboard and queryable through an "Ask my system" interface.
    </p>
    <div class="ds-hero-meta">
      <span class="ds-hero-meta-item"><strong>Owner</strong> &nbsp;Jeen (wishayajeen)</span>
      <span class="ds-hero-meta-item"><strong>Version</strong> &nbsp;1.0</span>
      <span class="ds-hero-meta-item"><strong>Fonts</strong> &nbsp;Space Grotesk · DM Sans · JetBrains Mono</span>
      <span class="ds-hero-meta-item"><strong>Style ref</strong> &nbsp;doodlio-template.webflow.io</span>
    </div>
  </div>
</div>

<!-- Main content -->
<div class="ds-page">

  <!-- ────────────────────────────────────────
       01 · PROJECT CONTEXT
  ──────────────────────────────────────── -->
  <section class="ds-section" id="context">
    <div class="ds-section-header">
      <span class="ds-section-num">01</span>
      <h2 class="ds-section-title">Project context</h2>
    </div>

    <div class="ds-card" style="margin-bottom:var(--space-6);">
      <p style="font-size:var(--text-lg);color:var(--fg-secondary);line-height:var(--leading-relaxed);margin:0 0 var(--space-4);">
        Jeen's portfolio is a <strong>living design system</strong> — structured data made visible. Instead of a static case-study portfolio, it showcases design thinking through the system itself.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:var(--space-4);">
        <div style="padding:var(--space-4);background:var(--color-gray-100);border-radius:var(--radius-md);">
          <p style="margin:0 0 var(--space-2);font-weight:600;font-family:var(--font-display);">Portfolio website</p>
          <p style="margin:0;font-size:var(--text-sm);color:var(--fg-secondary);">Main public-facing site — showcases work, thinking, and the design system itself.</p>
        </div>
        <div style="padding:var(--space-4);background:var(--color-gray-100);border-radius:var(--radius-md);">
          <p style="margin:0 0 var(--space-2);font-weight:600;font-family:var(--font-display);">Public dashboard</p>
          <p style="margin:0;font-size:var(--text-sm);color:var(--fg-secondary);">Visual display of the design system as structured data — this page.</p>
        </div>
        <div style="padding:var(--space-4);background:var(--color-yellow);border-radius:var(--radius-md);border:1.5px solid var(--color-black);">
